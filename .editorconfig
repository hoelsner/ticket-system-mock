# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.bash]
trim_trailing_whitespace = false
insert_final_newline = false
indent_style = space
indent_size = 2

[*.md]
insert_final_newline = false
indent_style = space
indent_size = 4
trim_trailing_whitespace = false

[*.yml]
indent_style = space
indent_size = 2

[*.yaml]
indent_style = space
indent_size = 2

[*.ts]
indent_style = space
indent_size = 2

[*.json]
[.github/workflows/*.yml]
indent_style = space
indent_size = 2

[.github/workflows/tasks/*.yml]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
indent_size = 4
